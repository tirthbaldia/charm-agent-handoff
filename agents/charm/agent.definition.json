{
  "name": "${AGENT_NAME}",
  "source": "azure-ai-foundry",
  "version": "${AGENT_VERSION}",
  "definition": {
    "kind": "prompt",
    "rai_config": {
      "rai_policy_name": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.CognitiveServices/accounts/${AI_SERVICES_ACCOUNT_NAME}/raiPolicies/Microsoft.DefaultV2"
    },
    "response_defaults": {
      "frequency_penalty": 0,
      "presence_penalty": 0,
      "temperature": 0,
      "top_p": 1
    },
    "model": "${FOUNDRY_MODEL_DEPLOYMENT_NAME}",
    "tools": [
      {
        "type": "file_search",
        "vector_store_ids": [
          "${VECTOR_STORE_ID}"
        ]
      },
      {
        "type": "memory_search",
        "memory_store_name": "${MEMORY_STORE_NAME}",
        "scope": "defaultUser",
        "update_delay": 30
      },
      {
        "type": "openapi",
        "openapi": {
          "name": "log_review_to_sql",
          "description": "Persist final review output to Azure SQL via Logic App.",
          "spec": {
            "info": {
              "description": "Posts Charm review results to Azure Logic App for SQL persistence.",
              "title": "Log Review To SQL",
              "version": "6.0.0"
            },
            "openapi": "3.0.1",
            "paths": {
              "/invoke": {
                "post": {
                  "operationId": "logReview",
                  "parameters": [
                    {
                      "in": "query",
                      "name": "api-version",
                      "required": true,
                      "schema": {
                        "default": "2019-05-01",
                        "type": "string"
                      }
                    },
                    {
                      "in": "query",
                      "name": "sp",
                      "required": true,
                      "schema": {
                        "default": "/triggers/When_an_HTTP_request_is_received/run",
                        "type": "string"
                      }
                    },
                    {
                      "in": "query",
                      "name": "sv",
                      "required": true,
                      "schema": {
                        "default": "1.0",
                        "type": "string"
                      }
                    },
                    {
                      "in": "query",
                      "name": "sig",
                      "required": true,
                      "schema": {
                        "default": "${LOGICAPP_CALLBACK_SIG}",
                        "type": "string"
                      }
                    }
                  ],
                  "requestBody": {
                    "content": {
                      "application/json": {
                        "schema": {
                          "properties": {
                            "business_unit": {
                              "type": "string"
                            },
                            "flags": {
                              "items": {
                                "properties": {
                                  "category": {
                                    "enum": [
                                      "Privacy",
                                      "Security",
                                      "Compliance",
                                      "Bias",
                                      "Other"
                                    ],
                                    "type": "string"
                                  },
                                  "citations": {
                                    "items": {
                                      "properties": {
                                        "clause_id": {
                                          "type": "string"
                                        },
                                        "doc_title": {
                                          "type": "string"
                                        },
                                        "language": {
                                          "enum": [
                                            "EN",
                                            "FR"
                                          ],
                                          "type": "string"
                                        },
                                        "page": {
                                          "type": "integer"
                                        },
                                        "requirement_id": {
                                          "type": "string"
                                        },
                                        "source_type": {
                                          "enum": [
                                            "external",
                                            "internal_rubric"
                                          ],
                                          "type": "string"
                                        },
                                        "source_url": {
                                          "type": "string"
                                        }
                                      },
                                      "required": [
                                        "doc_title",
                                        "page",
                                        "source_url",
                                        "source_type",
                                        "requirement_id",
                                        "clause_id",
                                        "language"
                                      ],
                                      "type": "object"
                                    },
                                    "type": "array"
                                  },
                                  "confidence": {
                                    "maximum": 1,
                                    "minimum": 0,
                                    "type": "number"
                                  },
                                  "flag_key": {
                                    "type": "string"
                                  },
                                  "impact": {
                                    "maximum": 10,
                                    "minimum": 0,
                                    "type": "integer"
                                  },
                                  "issue": {
                                    "type": "string"
                                  },
                                  "likelihood": {
                                    "maximum": 10,
                                    "minimum": 0,
                                    "type": "integer"
                                  },
                                  "rationale": {
                                    "type": "string"
                                  },
                                  "severity": {
                                    "enum": [
                                      "High",
                                      "Medium",
                                      "Low"
                                    ],
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "category",
                                  "severity",
                                  "issue",
                                  "rationale",
                                  "flag_key",
                                  "confidence",
                                  "citations"
                                ],
                                "type": "object"
                              },
                              "minItems": 1,
                              "type": "array"
                            },
                            "high_count": {
                              "minimum": 0,
                              "type": "integer"
                            },
                            "language": {
                              "enum": [
                                "EN",
                                "FR"
                              ],
                              "type": "string"
                            },
                            "low_count": {
                              "minimum": 0,
                              "type": "integer"
                            },
                            "med_count": {
                              "minimum": 0,
                              "type": "integer"
                            },
                            "overall_score": {
                              "maximum": 1,
                              "minimum": 0,
                              "type": "number"
                            },
                            "project_number": {
                              "type": "string"
                            },
                            "title": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "project_number",
                            "title",
                            "business_unit",
                            "language",
                            "flags"
                          ],
                          "type": "object"
                        }
                      }
                    },
                    "required": true
                  },
                  "responses": {
                    "200": {
                      "description": "Logged"
                    }
                  }
                }
              }
            },
            "servers": [
              {
                "url": "${LOGICAPP_LOGGER_SERVER_URL}"
              }
            ]
          },
          "auth": {
            "type": "anonymous"
          }
        }
      },
      {
        "type": "openapi",
        "openapi": {
          "name": "read_reviews_from_sql",
          "description": "Read saved review runs from Azure SQL via Logic App.",
          "spec": {
            "info": {
              "title": "Read Reviews From SQL",
              "version": "1.0.0"
            },
            "openapi": "3.0.1",
            "paths": {
              "/invoke": {
                "post": {
                  "operationId": "readReviews",
                  "parameters": [
                    {
                      "in": "query",
                      "name": "api-version",
                      "required": true,
                      "schema": {
                        "default": "2019-05-01",
                        "type": "string"
                      }
                    },
                    {
                      "in": "query",
                      "name": "sp",
                      "required": true,
                      "schema": {
                        "default": "/triggers/When_an_HTTP_request_is_received/run",
                        "type": "string"
                      }
                    },
                    {
                      "in": "query",
                      "name": "sv",
                      "required": true,
                      "schema": {
                        "default": "1.0",
                        "type": "string"
                      }
                    },
                    {
                      "in": "query",
                      "name": "sig",
                      "required": true,
                      "schema": {
                        "default": "${LOGICAPP_CALLBACK_SIG}",
                        "type": "string"
                      }
                    }
                  ],
                  "requestBody": {
                    "content": {
                      "application/json": {
                        "schema": {
                          "properties": {
                            "project_number": {
                              "maxLength": 50,
                              "type": "string"
                            },
                            "top_n": {
                              "maximum": 200,
                              "minimum": 1,
                              "type": "integer"
                            }
                          },
                          "type": "object"
                        }
                      }
                    },
                    "required": false
                  },
                  "responses": {
                    "200": {
                      "description": "ok"
                    }
                  }
                }
              }
            },
            "servers": [
              {
                "url": "${LOGICAPP_READER_SERVER_URL}"
              }
            ]
          },
          "auth": {
            "type": "anonymous"
          }
        }
      }
    ]
  }
}
