# Copy this file to project root as `.env` and populate values.

# Azure tenant/subscription
AZURE_SUBSCRIPTION_ID=<subscription-id>
AZURE_TENANT_ID=<tenant-id>
AZURE_RESOURCE_GROUP=<resource-group>
AZURE_LOCATION=<azure-location>

# Foundry / Agent
FOUNDRY_PROJECT_ENDPOINT=<https://<project-endpoint>>
FOUNDRY_PROJECT_NAME=<foundry-project-name>
FOUNDRY_MODEL_DEPLOYMENT_NAME=<model-deployment-name>
AGENT_NAME=Charm
AGENT_VERSION=<agent-version>
VECTOR_STORE_ID=<vector-store-id>
MEMORY_STORE_NAME=<memory-store-name>

# Logic Apps tool endpoints
LOGICAPP_LOGGER_NAME=<logger-workflow-name>
LOGICAPP_READER_NAME=<reader-workflow-name>
LOGICAPP_LOGGER_SERVER_URL=<https://.../triggers/.../paths>
LOGICAPP_READER_SERVER_URL=<https://.../triggers/.../paths>
LOGICAPP_LOGGER_SIG=<logger-callback-signature>
LOGICAPP_READER_SIG=<reader-callback-signature>
LOGICAPP_CALLBACK_SIG=<generic-callback-signature-if-shared>
SQL_API_CONNECTION_NAME=<sql-connection-resource-name>

# SQL
SQL_SERVER_FQDN=<server>.database.windows.net
SQL_DATABASE_NAME=<database-name>
SQL_USERNAME=<sql-user>
SQL_PASSWORD=<sql-password>

# FastAPI utility app
APP_HOST=0.0.0.0
APP_PORT=8080
